# Server
Port=5000

# Auth
JWT_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (object storage for audio files)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Stripe (payments)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# LLM (protocol chat)
EMERGENT_LLM_KEY=

# Rate limiting (optional — falls back to in-memory if not set)
REDIS_URL=
PROTOCOL_CHAT_RATE_LIMIT=20

# Admin
ADMIN_BOOTSTRAP_SECRET=

# Production flags
COOKIE_SECURE=true
CORS_ORIGINS=https://yourdomain.com
