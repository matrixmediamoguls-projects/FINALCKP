{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_APP_BACKEND_URL": "@vite_app_backend_url",
    "VITE_APP_SUPABASE_URL": "@vite_app_supabase_url",
    "VITE_APP_SUPABASE_ANON_KEY": "@vite_app_supabase_anon_key",
    "VITE_APP_R2_PUBLIC_BASE_URL": "@vite_app_r2_public_base_url",
    "VITE_APP_GOOGLE_CLIENT_ID": "@vite_app_google_client_id"
  }
}
